@model SchoolExample.Application.Dtos.Requests.Exams.ExamRegisterRequest
@{
    ViewData["Title"] = "İmtahan Əlavə Et";
}

<div class="card shadow-sm w-50 mx-auto mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Yeni İmtahan Nəticəsi</h5>
    </div>
    <div class="card-body">
        <form asp-action="Register" method="post">
            <div class="mb-3">
                <label asp-for="LessonId" class="form-label fw-bold">Dərs Seçin</label>
                <select asp-for="LessonId" asp-items="ViewBag.Lessons" class="form-select">
                    <option value="">-- Dərs Seçin --</option>
                </select>
                <span asp-validation-for="LessonId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StudentId" class="form-label fw-bold">Şagird Seçin</label>
                <select asp-for="StudentId" asp-items="ViewBag.Students" class="form-select">
                    <option value="">-- Şagird Seçin --</option>
                </select>
                <span asp-validation-for="StudentId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ExamDate" class="form-label fw-bold">İmtahan Tarixi</label>
                <input asp-for="ExamDate" type="date" class="form-control" />
                <span asp-validation-for="ExamDate" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Grade" class="form-label fw-bold">Qiymət (0-10)</label>
                <input asp-for="Grade" type="number" class="form-control" />
                <span asp-validation-for="Grade" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a asp-action="Index" class="btn btn-light border">Ləğv Et</a>
                <button type="submit" class="btn btn-success">Yadda Saxla</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}